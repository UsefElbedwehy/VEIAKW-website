{
  "name": "thouqi-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Premium, configurable, multilingual e-commerce platform (Next.js + Supabase).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "migrate": "node scripts/migrate.mjs",
    "seed": "tsx scripts/seed.ts",
